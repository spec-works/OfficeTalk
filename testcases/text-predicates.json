      "each": false,
      "operations": [{ "type": "DELETE" }]
    },
    {
      "address": "body/paragraph[text$=\"ends with this.\"]",
      "each": false,
      "operations": [{ "type": "DELETE" }]
    },
    {
      "address": "body/paragraph[text~=\"^Chapter \\d+\"]",
      "each": false,
      "operations": [{ "type": "DELETE" }]
